{
  "manifest_version": 3,
  "name": "GrammarSmash",
  "version": "1.0.0",
  "description": "Fast grammar shooter — spot wrong sentences and shoot them down",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://azgplnfczforimmtpznx.supabase.co/*"],
  "icons": { "128": "assets/icon.png" },
  "action": {
    "default_icon": { "128": "assets/icon.png" }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["idle.js", "toast.js"]
    }
  ]
}
